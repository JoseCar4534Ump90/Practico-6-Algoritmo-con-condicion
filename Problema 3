#include <iostream>
using namespace std;

void desglosarNumero(int n) {
    int m = n / 1000;
    int c = (n % 1000) / 100;
    int d = (n % 100) / 10;
    int u = n % 10;
    cout << "Miles: " << m << "\nCentenas: " << c << "\nDecenas: " << d << "\nUnidades: " << u << endl;
}

int main() {
    int num;
    cout << "Ingrese numero (< 10000): ";
    cin >> num;
    desglosarNumero(num);
    return 0;
}
