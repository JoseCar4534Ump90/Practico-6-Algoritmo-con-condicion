#include <iostream>
using namespace std;

void determinarEstacion(int d, int m) {
    if ((m == 9 && d >= 21) || (m == 10) || (m == 11) || (m == 12 && d < 21))
        cout << "Primavera" << endl;
    else if ((m == 12 && d >= 21) || (m == 1) || (m == 2) || (m == 3 && d < 21))
        cout << "Verano" << endl;
    else if ((m == 3 && d >= 21) || (m == 4) || (m == 5) || (m == 6 && d < 21))
        cout << "Otono" << endl;
    else
        cout << "Invierno" << endl;
}

int main() {
    int d, m, a;
    cout << "Fecha (dia mes año): "; cin >> d >> m >> a;
    determinarEstacion(d, m);
    return 0;
}
