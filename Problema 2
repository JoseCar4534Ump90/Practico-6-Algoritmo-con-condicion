#include <iostream>
#include <cmath>
using namespace std;

void resolverCuadraticaSimple(double a, double b, double c) {
    double discriminante = pow(b, 2) - (4 * a * c);
    if (discriminante >= 0) {
        double x1 = (-b + sqrt(discriminante)) / (2 * a);
        double x2 = (-b - sqrt(discriminante)) / (2 * a);
        cout << "x1 = " << x1 << ", x2 = " << x2 << endl;
    } else {
        cout << "No existen soluciones reales." << endl;
    }
}

int main() {
    double a, b, c;
    cout << "Ingrese coeficientes a, b y c: ";
    cin >> a >> b >> c;
    resolverCuadraticaSimple(a, b, c);
    return 0;
}
