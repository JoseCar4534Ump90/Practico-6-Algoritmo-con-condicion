#include <iostream>
#include <cmath>
using namespace std;

void resolverCuadraticaCompleta(double a, double b, double c) {
    if (a == 0) {
        if (b == 0) cout << (c == 0 ? "Solucion infinita" : "Sin solucion") << endl;
        else cout << "Lineal: x = " << -c / b << endl;
    } else {
        double disc = b * b - 4 * a * c;
        if (disc >= 0) {
            cout << "x1 = " << (-b + sqrt(disc)) / (2 * a) << endl;
            cout << "x2 = " << (-b - sqrt(disc)) / (2 * a) << endl;
        } else {
            double real = -b / (2 * a);
            double imag = sqrt(-disc) / (2 * a);
            cout << "x1 = " << real << " + " << imag << "i" << endl;
            cout << "x2 = " << real << " - " << imag << "i" << endl;
        }
    }
}

int main() {
    double a, b, c;
    cin >> a >> b >> c;
    resolverCuadraticaCompleta(a, b, c);
    return 0;
}
