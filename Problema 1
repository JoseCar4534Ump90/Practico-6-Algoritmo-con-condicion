#include <iostream>
using namespace std;

void calcularCostoCarta(double p) {
    if (p <= 0) cout << "Peso no valido." << endl;
    else if (p < 50) cout << "Costo: Bs. 1.50" << endl;
    else if (p <= 100) cout << "Costo: Bs. 4.00" << endl;
    else if (p <= 200) cout << "Costo: Bs. 6.00" << endl;
    else if (p <= 350) cout << "Costo: Bs. 10.50" << endl;
    else if (p <= 500) cout << "Costo: Bs. 15.00" << endl;
    else cout << "NO PUEDE ENVIAR COMO CARTA" << endl;
}

int main() {
    double peso;
    cout << "Ingrese el peso en gramos: ";
    cin >> peso;
    calcularCostoCarta(peso);
    return 0;
}
