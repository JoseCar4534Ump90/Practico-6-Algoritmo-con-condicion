#include <iostream>
using namespace std;

void resolverSistema(double a, double b, double c, double d, double e, double f) {
    double det = a * e - b * d;
    if (det != 0) {
        double x = (c * e - b * f) / det;
        double y = (a * f - c * d) / det;
        cout << "Solucion unica: X=" << x << ", Y=" << y << endl;
    } else {
        if ((a / d == c / f) || (b / e == c / f)) cout << "Infinitas soluciones." << endl;
        else cout << "Sin solucion." << endl;
    }
}

int main() {
    double a, b, c, d, e, f;
    cout << "Ecuacion 1 (a b c): "; cin >> a >> b >> c;
    cout << "Ecuacion 2 (d e f): "; cin >> d >> e >> f;
    resolverSistema(a, b, c, d, e, f);
    return 0;
}
